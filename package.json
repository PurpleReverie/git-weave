{
  "name": "git-weave",
  "version": "0.1.0",
  "description": "Git-aware CLI for managing child repositories via .thread files",
  "main": "dist/index.js",
  "bin": {
    "weave": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "prepare": "npm run build"
  },
  "files": [
    "dist"
  ],
  "author": "PurpleReverie",
  "license": "MIT",
  "homepage": "https://github.com/PurpleReverie/git-weave#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PurpleReverie/git-weave.git"
  },
  "bugs": {
    "url": "https://github.com/PurpleReverie/git-weave/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": ["git", "repository", "sync", "cli", "devtools", "multi-repo", "submodules"],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "14.0.3",
    "dotenv": "17.4.0",
    "simple-git": "3.33.0"
  },
  "devDependencies": {
    "@types/node": "25.5.1",
    "ts-node": "10.9.2",
    "typescript": "6.0.2"
  }
}
